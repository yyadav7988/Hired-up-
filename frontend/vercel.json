{
  "outputDirectory": "api/assets",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/auth", "destination": "/auth.html" },
    { "source": "/profile", "destination": "/profile.html" },
    { "source": "/recruiter", "destination": "/recruiter.html" },
    { "source": "/interview", "destination": "/interview.html" },
    { "source": "/feedback", "destination": "/feedback.html" },
    { "source": "/skillgap", "destination": "/skillgap.html" },
    { "source": "/post-job", "destination": "/post-job.html" },
    { "source": "/candidates", "destination": "/candidates.html" },
    { "source": "/leaderboard", "destination": "/leaderboard.html" },
    { "source": "/pricing", "destination": "/pricing.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
