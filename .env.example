# HiredUp - Environment Variables
# Copy this file to .env and fill in your values

# ─── Core Backend ──────────────────────────────────────────────────
PORT=3000

# PostgreSQL connection (leave empty to run in DEMO/in-memory mode)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/skillfirst_hire

# JWT — CHANGE THIS IN PRODUCTION
JWT_SECRET=dev-secret-change-in-production-use-32-char-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Set to 'true' to skip PostgreSQL and always use in-memory demo mode
SKIP_DB=false

# ─── ML Service ────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:5000

# Gemini AI (used for interview Q generation and evaluation)
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Code Execution ────────────────────────────────────────────────
# Optional: Judge0 API key for secure multi-language code execution
# Free tier: 100 req/day — https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_KEY=
JUDGE0_HOST=judge0-ce.p.rapidapi.com

# ─── ML Service (Python) ───────────────────────────────────────────
UPLOAD_FOLDER=/tmp/skillfirst_uploads

# ─── Environment ───────────────────────────────────────────────────
NODE_ENV=development
